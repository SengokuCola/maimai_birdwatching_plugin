{
  "manifest_version": 2,
  "version": "1.1.1",
  "name": "麦麦观鸟插件 (MaiMai Birdwatching Plugin)",
  "description": "提供基于百度智能云图像识别接口的鸟类、动物、植物和菜品识别工具，并支持可选 HHo 懂鸟鸟类识别。",
  "author": {
    "name": "SengokuCola",
    "url": "https://github.com/SengokuCola"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/SengokuCola/maimai_birdwatching_plugin",
    "homepage": "https://github.com/SengokuCola/maimai_birdwatching_plugin",
    "documentation": "https://cloud.baidu.com/doc/IMAGERECOGNITION/s/Zk3bcxdfr",
    "issues": "https://github.com/SengokuCola/maimai_birdwatching_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "Pillow",
      "version_spec": ">=11.3.0"
    }
  ],
  "capabilities": [
    "message.get_by_id",
    "send.image"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "SengokuCola.maimai-birdwatching-plugin"
}
